# Terraform local files
.terraform/
*.tfstate
*.tfstate.*

# Terraform lock file (optional to ignore)
# (recommended to KEEP it in repo → so comment this line if needed)
# .terraform.lock.hcl

# Sensitive variable files
*.tfvars
*.tfvars.json

# Crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Plan output files
*.out
*.plan

# OS / Editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# SSH keys (VERY IMPORTANT)
*.pem
*.key

# Kubernetes config (optional)
kubeconfig