# create open id connect 
eksctl utils associate-iam-oidc-provider --region=us-east-1 --cluster="eks-cluster-terraform" --approve



# create  Iamservice account for secret key (here we are assigning policy to openidconnect)

eksctl create iamserviceaccount --cluster="eks-cluster-terraform" --namespace=chat-app --name=aws-service-account-secret --role-name myClusterSecrets123 --attach-policy-arn arn:aws:iam::aws:policy/SecretsManagerReadWrite --approve --region=us-east-1 --override-existing-serviceaccounts







# check service account
kubectl get sa -n chat-app
kubectl get serviceaccount   #sa is service account




# Install  Custom Resource Definitions on EKS : Install csi driver by helm

helm repo add secrets-store-csi-driver https://kubernetes-sigs.github.io/secrets-store-csi-driver/charts


helm repo ls

helm install secrets-store-aws secrets-store-csi-driver/secrets-store-csi-driver --namespace kube-system --set clusterName=eks-cluster-terraform --set serviceAccount.create=false --set serviceAccount.name=aws-service-account-secret
helm ls --namespace kube-system


kubectl get pods -n kube-system


helm ls --namespace kube-system

# Install AWS provider

kubectl apply -f https://raw.githubusercontent.com/aws/secrets-store-csi-driver-provider-aws/main/deployment/aws-provider-installer.yaml

kubectl get crd | grep secretproviderclass



#kubectl get deployment -n kube-system aws-load-balancer-controller


kubectl get secret -n chat-app

kubectl port-forward deployment/frontend-deployment 8080:80 -n chat-app